    {
      "parameters": {
        "jsCode": "// Loop through every item coming into the node\nfor (const item of $input.all()) {\n  let text = item.json.text || \"\"; // Fallback to empty string if text is missing\n  \n  const replyPatterns = [\n    /^On.*wrote:/m,\n    /^Am.*schrieb:/m, // German support for elbdudler!\n    /---Original Message---/i,\n    /________________________________/\n  ];\n\n  let cleanedText = text;\n\n  for (const pattern of replyPatterns) {\n    const match = text.match(pattern);\n    if (match && match.index > 0) {\n      cleanedText = text.substring(0, match.index);\n      break; // Stop after the first match to keep the freshest reply\n    }\n  }\n\n  // Explicitly set the new field on the JSON object\n  item.json.cleaned_text = cleanedText.trim();\n}\n\n// Return the modified array of items\nreturn $input.all();"
      },
